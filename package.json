{
  "name": "@codepilot/ai",
  "version": "1.0.0",
  "description": "AI-powered engineering workflow toolkit for modern software development.",
  "license": "MIT",
  "private": false,
  "bin": {
    "codepilot": "./bin/codepilot.cjs"
  },
  "files": [
    "bin",
    "dist",
    "scripts",
    "src",
    "templates",
    "README.md",
    "README.zh-CN.md"
  ],
  "engines": {
    "node": ">=16.15.0"
  },
  "scripts": {
    "build": "node ./scripts/build.cjs",
    "smoke": "node ./dist/cli.cjs --help",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "commander": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.6",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5",
    "vitest": "^1.0.0"
  }
}
